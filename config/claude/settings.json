{
  "permissions": {
    "allow": [
      "Read(//workspace/**)",
      "Edit(//workspace/**)",
      "Write(//workspace/**)",
      "WebSearch",
      "WebFetch",
      "Bash"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(socat:*)",
      "Read(**/.env)",
      "Read(**/.env.*.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
